# Environment variables for this project.
# Set these in the Bzync Cloud dashboard under each environment.
#
# The platform seeds these as the project's real env vars on first deploy
# — any value literally "changeme" is replaced with a generated random
# secret at seed time, never passed through as-is.

N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=changeme
WEBHOOK_URL=https://your-domain.com
GENERIC_TIMEZONE=UTC
TZ=UTC
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true

# Database — link a Postgres database in the Bzync Cloud dashboard.
# The platform injects DATABASE_HOST, DATABASE_PORT, DATABASE_NAME,
# DATABASE_USER, and DATABASE_PASSWORD automatically. The start script
# translates these to n8n's format — no manual configuration needed.
DB_POSTGRESDB_SCHEMA=public

# ── First admin account (auto-provisioned on every boot) ───────────────────
# n8n has no signup-wizard bypass of its own — without this, the first
# visit to the UI demands creating an owner account by hand. start.sh sets
# N8N_INSTANCE_OWNER_MANAGED_BY_ENV=true and bcrypt-hashes
# N8N_ADMIN_PASSWORD into N8N_INSTANCE_OWNER_PASSWORD_HASH for you (n8n
# only accepts a pre-hashed password, never plaintext, for this variable).
# Leaving N8N_ADMIN_PASSWORD=changeme in place gets you a generated random
# password the same way N8N_ENCRYPTION_KEY does; view it in the
# dashboard's Variables tab after deploy. Because
# N8N_INSTANCE_OWNER_MANAGED_BY_ENV re-applies these on every startup, the
# owner's name/email/password stay locked to what's set here — change
# them here (not in the n8n UI) if you need to rotate the password later.
N8N_ADMIN_EMAIL=admin@your-domain.example.com
N8N_ADMIN_PASSWORD=changeme
N8N_ADMIN_FIRST_NAME=Admin
N8N_ADMIN_LAST_NAME=User
