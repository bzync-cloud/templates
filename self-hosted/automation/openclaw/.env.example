# Environment variables for this project.
# Set these in the Bzync Cloud dashboard under each environment.

# Skip the interactive onboarding wizard — required since the container has
# no TTY. Configure the model provider afterwards from the gateway's web UI
# at your app's URL instead.
OPENCLAW_SKIP_ONBOARDING=1

# Sandboxes agent-run commands (recommended).
OPENCLAW_SANDBOX=1

# Auth token for the gateway's control API/UI — this is the only login
# credential OpenClaw has (token-based auth, no separate admin account).
# Without it, the gateway generates one on first boot that won't survive a
# redeploy. Leave this as "changeme": the platform replaces any literal
# "changeme" value with a generated random secret at seed time, the same
# mechanism every other credential in this catalog uses — view the real
# value in the dashboard's Variables tab after deploy.
OPENCLAW_GATEWAY_TOKEN=changeme

# Optional: OpenTelemetry traces/metrics export endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=
