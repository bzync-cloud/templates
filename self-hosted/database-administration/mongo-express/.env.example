# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is.

# ── Database connection ─────────────────────────────────────────────────────
# Deploy `database/mongodb` from this catalog as its own app, then set
# DB_HOST, DB_PORT, DB_NAME, DB_USER, and DB_PASSWORD here from the values
# you configured there (no dashboard linking on this tier). start.sh
# translates these to mongo-express's native ME_CONFIG_MONGODB_* format.
#
# Without a linked database (e.g. plain `docker run`), mongo-express falls
# back to the image's built-in default of a host named "mongo" on the same
# Docker network — see "Run locally" in README.md.

# ── mongo-express's own login (production-hardened default) ────────────────
# Protects the mongo-express UI itself, separate from the MongoDB
# credentials above. Leave ME_CONFIG_BASICAUTH_PASSWORD as "changeme" — see
# note above. Set ME_CONFIG_BASICAUTH=false to remove this prompt entirely
# (not recommended on a public domain — see README.md).
ME_CONFIG_BASICAUTH=true
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=changeme

# ── Access scope ─────────────────────────────────────────────────────────────
# true: browse every database visible to the connected user (typical for an
# admin-only tool talking to a dedicated MongoDB instance). false: restrict
# to ME_CONFIG_MONGODB_AUTH_DATABASE only.
ME_CONFIG_MONGODB_ENABLE_ADMIN=true
