# Environment variables for this project.
# Set these in the Bzync Cloud dashboard under each environment.
#
# Plane's all-in-one image needs FOUR external services just to start — it
# has no embedded database, cache, queue, or file storage of its own. The
# values below match "Run locally" in README.md (four companion
# containers); replace them with real values once you've linked/provisioned
# each service for a real deployment — see README.md for what each one is
# for and where it can come from.

DOMAIN_NAME=localhost
APP_PROTOCOL=http
SECRET_KEY=change-me

# ── Postgres — deploy `database/postgres` from this catalog as its own app ─
DATABASE_URL=postgres://plane:change-me@db:5432/plane

# ── Redis — deploy `database/redis` from this catalog as its own app ──────
REDIS_URL=redis://redis:6379/

# ── AMQP broker — no Bzync-managed equivalent; bring your own RabbitMQ ────
AMQP_URL=amqp://plane:change-me@rabbitmq:5672/

# ── S3-compatible object storage — no Bzync-managed equivalent; bring ─────
# your own bucket (AWS S3, Cloudflare R2, Backblaze B2, self-hosted MinIO)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_BUCKET_NAME=plane
# AWS_S3_ENDPOINT_URL=https://your-minio-or-r2-endpoint.example.com

# ── Optional ─────────────────────────────────────────────────────────────
# FILE_SIZE_LIMIT=5242880
