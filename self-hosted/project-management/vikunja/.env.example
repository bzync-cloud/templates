# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is.

# ── Required for a real deployment ─────────────────────────────────────────
# Set this once you have a domain attached in the dashboard — Vikunja
# refuses to start with CORS enabled (the default) unless this is set, and
# uses it to build links in emails and the frontend's API base URL.
VIKUNJA_SERVICE_PUBLICURL=https://your-domain.example.com/

# ── Security ─────────────────────────────────────────────────────────────
VIKUNJA_SERVICE_SECRET=changeme

# ── Access control — production-hardened default ────────────────────────
# Set to true to allow open sign-up.
VIKUNJA_SERVICE_ENABLEREGISTRATION=false

# ── Default: SQLite ──────────────────────────────────────────────────────
# Fine for solo/small use; the whole instance's state lives in the /db and
# /app/vikunja/files volumes, no separate database to run.

# ── Recommended for production: Postgres or MySQL ───────────────────────
# Deploy `database/postgres` or `database/mysql` from this catalog as its
# own app, then set these from the values you configured there (no
# dashboard linking on this tier):
# VIKUNJA_DATABASE_TYPE=postgres
# VIKUNJA_DATABASE_HOST=<POSTGRES_HOST>
# VIKUNJA_DATABASE_PORT=<POSTGRES_PORT>
# VIKUNJA_DATABASE_DATABASE=<POSTGRES_DB>
# VIKUNJA_DATABASE_USER=<POSTGRES_USER>
# VIKUNJA_DATABASE_PASSWORD=<POSTGRES_PASSWORD>
# VIKUNJA_DATABASE_SSLMODE=disable

# ── Mailer (optional, needed for password resets / reminders) ─────────────
# VIKUNJA_MAILER_ENABLED=true
# VIKUNJA_MAILER_HOST=smtp.example.com
# VIKUNJA_MAILER_PORT=587
# VIKUNJA_MAILER_USERNAME=
# VIKUNJA_MAILER_PASSWORD=
# VIKUNJA_MAILER_FROMEMAIL=vikunja@your-domain.example.com
