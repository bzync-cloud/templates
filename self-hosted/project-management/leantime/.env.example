# Environment variables for this project.
# Set these in the Bzync Cloud dashboard under each environment.
#
# Unlike the other project-management templates here, Leantime has no
# SQLite fallback — it needs a real MySQL/MariaDB database to start at all.
# The values below match "Run locally" in README.md (a companion MariaDB
# container named "db"); replace them with the values the dashboard shows
# you once you link a real MySQL/MariaDB database from Databases → Create.

LEAN_DB_HOST=db
LEAN_DB_PORT=3306
LEAN_DB_DATABASE=leantime
LEAN_DB_USER=leantime
LEAN_DB_PASSWORD=change-me

# ── Recommended for a real deployment ──────────────────────────────────────
# Set this once you have a domain attached in the dashboard — used to build
# absolute links (e.g. in notification emails).
# LEAN_APP_URL=https://your-domain.example.com

# ── Mailer (optional, needed for invites / notifications) ──────────────────
# LEAN_EMAIL_USE_SMTP=true
# LEAN_EMAIL_SMTP_HOSTS=smtp.example.com
# LEAN_EMAIL_SMTP_PORT=587
# LEAN_EMAIL_SMTP_AUTH=true
# LEAN_EMAIL_SMTP_USERNAME=
# LEAN_EMAIL_SMTP_PASSWORD=
# LEAN_EMAIL_RETURN=leantime@your-domain.example.com
