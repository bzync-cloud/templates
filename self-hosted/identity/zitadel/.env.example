# Passed to `docker run --env-file .env` for local dev, and also how this
# deploys on Bzync Cloud itself. The platform DOES seed these as the
# project's real env vars on first deploy (see BZYNC_CLOUD) — but any value
# literally "changeme" is replaced with a generated random secret at seed
# time, never passed through as-is.

# ── Security ────────────────────────────────────────────────────────────
# Must be exactly 32 characters — Zitadel uses it to encrypt data at rest
# and rejects anything else at startup. Unlike other secrets in this repo,
# don't leave this as "changeme" (8 chars, and not random) — generate a
# real one and paste it in:
#   openssl rand -base64 32 | head -c 32
ZITADEL_MASTERKEY=

# ── First admin account ──────────────────────────────────────────────────
# ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME/EMAIL_ADDRESS are baked into the
# Dockerfile; the password is deliberately not, and isn't set here either
# by default. Zitadel's password complexity policy requires upper+lower
# case, a digit, and a symbol — the repo-standard "changeme" placeholder
# fails it outright (Errors.User.PasswordComplexityPolicy.HasUpper) and
# crashes first-boot setup instead of just warning, the same trap
# GITLAB_ROOT_PASSWORD avoids elsewhere in this repo. Set a real value
# here before first deploy, or leave it unset entirely — Zitadel still
# boots fine either way (confirmed by testing), but the first admin has no
# usable password until you set one via the console's password-reset flow.
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=

# ── Database (required — no SQLite fallback) ────────────────────────────
# Deploy `data-stores/relational/postgres` from this catalog as its own
# app, then set these from the values you configured there (no dashboard
# linking on this tier) — "db" below is a placeholder matching "Run
# locally"'s companion Postgres container, not a real deployed hostname.
# Using the same username for both USER and ADMIN below (as Postgres'
# own template does) makes Zitadel skip a separate CREATE USER/GRANT step
# it would otherwise attempt with its own admin credentials.
ZITADEL_DATABASE_POSTGRES_HOST=db
ZITADEL_DATABASE_POSTGRES_PORT=5432
ZITADEL_DATABASE_POSTGRES_DATABASE=app
ZITADEL_DATABASE_POSTGRES_USER_USERNAME=app
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=changeme
ZITADEL_DATABASE_POSTGRES_ADMIN_USERNAME=app
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=changeme

# ── Recommended for a real deployment ────────────────────────────────────
# Set once you have a domain attached — Zitadel uses it to build absolute
# URLs (OIDC discovery, redirect URIs, emails) and validates the incoming
# Host header against it.
# ZITADEL_EXTERNALDOMAIN=your-domain.example.com
