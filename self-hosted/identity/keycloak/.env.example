# Passed to `docker run --env-file .env` for local dev, and also how this
# deploys on Bzync Cloud itself. The platform DOES seed these as the
# project's real env vars on first deploy (see BZYNC_CLOUD) — but any value
# literally "changeme" is replaced with a generated random secret at seed
# time, never passed through as-is.

# ── First admin account ──────────────────────────────────────────────────
# Keycloak creates this account itself on first boot from these two vars
# (native to the upstream image, no wrapper script needed here). Leaving
# KC_BOOTSTRAP_ADMIN_PASSWORD=changeme in place gets you a strong generated
# password the same way other templates' secrets do; find it in the
# dashboard's Variables tab after deploy. This account only exists until
# you create a real admin in the master realm — Keycloak deletes the
# temporary one the first time a permanent admin logs in.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=changeme

# ── Database (required — no SQLite/H2 fallback in production mode) ──────
# Deploy `data-stores/relational/postgres` from this catalog as its own
# app, then set these from the values you configured there (no dashboard
# linking on this tier) — "db" below is a placeholder matching "Run
# locally"'s companion Postgres container, not a real deployed hostname.
KC_DB_URL=jdbc:postgresql://db:5432/app
KC_DB_USERNAME=app
KC_DB_PASSWORD=changeme

# ── Recommended for a real deployment ────────────────────────────────────
# Set once you have a domain attached in the dashboard — Keycloak uses it
# to build absolute links (realm metadata, redirect URIs, emails) and to
# validate the Host header against (KC_HOSTNAME_STRICT is left false in
# the Dockerfile, so this isn't strictly required to boot, but every
# generated URL is wrong without it).
# KC_HOSTNAME=your-domain.example.com
