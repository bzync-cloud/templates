# Passed to `docker run --env-file .env` for local dev, and also how this
# deploys on Bzync Cloud itself. The platform DOES seed these as the
# project's real env vars on first deploy (see BZYNC_CLOUD) — but any value
# literally "changeme" is replaced with a generated random secret at seed
# time, never passed through as-is.

# ── Security ────────────────────────────────────────────────────────────
# Needs to be long and random — authentik uses it to sign cookies and
# tokens. Leave "changeme" as-is to get a generated value.
AUTHENTIK_SECRET_KEY=changeme

# ── First admin account (akadmin) ───────────────────────────────────────
# authentik creates this account itself on first boot from these two vars
# (native to the upstream image, no wrapper script needed here). Leaving
# AUTHENTIK_BOOTSTRAP_PASSWORD=changeme in place gets you a strong
# generated password the same way SECRET_KEY does; find it in the
# dashboard's Variables tab after deploy.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@your-domain.example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=changeme

# ── Database (required — no SQLite fallback) ────────────────────────────
# Deploy `data-stores/relational/postgres` from this catalog as its own
# app, then set these from the values you configured there (no dashboard
# linking on this tier) — "db" below is a placeholder matching "Run
# locally"'s companion Postgres container, not a real deployed hostname.
# As of authentik 2025.10, Redis is no longer required — caching, tasks,
# and the embedded outpost all run on Postgres.
AUTHENTIK_POSTGRESQL__HOST=db
AUTHENTIK_POSTGRESQL__NAME=app
AUTHENTIK_POSTGRESQL__USER=app
AUTHENTIK_POSTGRESQL__PASSWORD=changeme

# ── Recommended for a real deployment ────────────────────────────────────
# Unlike most templates in this repo, the public domain isn't set through
# an env var here — after deploying, log in as akadmin and set it under
# System → Brands → (your brand) → Domain. AUTHENTIK_ERROR_REPORTING__ENABLED
# is left at its production-hardened default of false (no telemetry sent
# upstream on errors) — see Dockerfile.
