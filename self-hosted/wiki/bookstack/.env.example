# Passed to `docker run --env-file .env` for local dev, and also how this
# deploys on Bzync Cloud itself. The platform DOES seed these as the
# project's real env vars on first deploy (see BZYNC_CLOUD) — but any value
# literally "changeme" is replaced with a generated random secret at seed
# time, never passed through as-is.

# ── Required for a real deployment ─────────────────────────────────────────
# Set once you have a domain attached — BookStack bakes this into every
# link it generates (page URLs, image URLs, email links).
APP_URL=https://your-domain.example.com

# ── Security ────────────────────────────────────────────────────────────
# BookStack (Laravel) needs a real "base64:<32 random bytes>" key, not the
# repo-standard "changeme" convention — generate one and paste it in:
#   php -r "echo 'base64:'.base64_encode(random_bytes(32));"
# or, using the image itself:
#   docker run --rm --entrypoint /usr/bin/php lscr.io/linuxserver/bookstack:latest \
#     /app/www/artisan key:generate --show
APP_KEY=

# ── Database (required — no SQLite fallback) ────────────────────────────
# Deploy `data-stores/relational/mariadb` from this catalog as its own
# app, then set these from the values you configured there (no dashboard
# linking on this tier) — "db" below is a placeholder matching "Run
# locally"'s companion MariaDB container, not a real deployed hostname.
DB_HOST=db
DB_PORT=3306
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=changeme
