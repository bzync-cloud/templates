# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is.
#
# Forgejo is a Gitea fork and kept the GITEA__<section>__<KEY> env-to-ini
# system — the platform writes the result to /data/gitea/conf/app.ini on
# boot (only overwriting keys you set here — INTERNAL_TOKEN and the OAuth2
# JWT_SECRET are generated by Forgejo itself on first boot and persisted to
# that same file, so they survive redeploys as long as the /data volume
# does).

# ── Required for a real deployment ─────────────────────────────────────────
# Set these once you have a domain attached in the dashboard.
GITEA__server__ROOT_URL=https://your-domain.example.com/
GITEA__server__DOMAIN=your-domain.example.com

# ── Security (baked into the image, listed here for visibility) ───────────
GITEA__security__INSTALL_LOCK=true
GITEA__security__SECRET_KEY=changeme

# ── Access control — production-hardened defaults ──────────────────────────
# Set both to false to open the instance up to public sign-up.
GITEA__service__DISABLE_REGISTRATION=true
GITEA__service__REQUIRE_SIGNIN_VIEW=true

# ── Default: SQLite ──────────────────────────────────────────────────────
# Fine for small teams; a single file under /data, no separate DB to run.
GITEA__database__DB_TYPE=sqlite3

# ── Recommended for production: Postgres ────────────────────────────────
# Deploy `database/postgres` from this catalog as its own app, then set
# these from the values you configured there (no dashboard linking on this
# tier):
# GITEA__database__DB_TYPE=postgres
# GITEA__database__HOST=<POSTGRES_HOST>:<POSTGRES_PORT>
# GITEA__database__NAME=<POSTGRES_DB>
# GITEA__database__USER=<POSTGRES_USER>
# GITEA__database__PASSWD=<POSTGRES_PASSWORD>

# ── Actions (Forgejo's built-in CI, off until a runner is registered) ─────
# Enabled by default. A runner needs registering separately (forgejo-runner)
# — this template deploys the server only.
# GITEA__actions__ENABLED=true

# ── Mailer (optional, needed for password resets / notifications) ─────────
# GITEA__mailer__ENABLED=true
# GITEA__mailer__SMTP_ADDR=smtp.example.com
# GITEA__mailer__SMTP_PORT=587
# GITEA__mailer__USER=
# GITEA__mailer__PASSWD=
# GITEA__mailer__FROM=forgejo@your-domain.example.com
