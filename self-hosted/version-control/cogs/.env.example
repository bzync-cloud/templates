# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is.
#
# Gogs has no env-to-ini system like Gitea/Forgejo's GITEA__ vars — these
# get rendered into /data/gogs/conf/app.ini by entrypoint.sh (via envsubst),
# once, on first boot only. Changing a value here after the instance has
# already booted once has no effect unless you also delete the rendered
# app.ini from the volume (which also discards SECRET_KEY unless you keep
# it the same).

# ── Required for a real deployment ─────────────────────────────────────────
# Set these once you have a domain attached in the dashboard.
GOGS_DOMAIN=your-domain.example.com
GOGS_ROOT_URL=https://your-domain.example.com/

# ── Security ────────────────────────────────────────────────────────────
GOGS_SECRET_KEY=changeme

# ── Access control — production-hardened defaults ──────────────────────────
# Set both to false to open the instance up to public sign-up.
GOGS_DISABLE_REGISTRATION=true
GOGS_REQUIRE_SIGNIN_VIEW=true

# ── Default: SQLite ──────────────────────────────────────────────────────
# Fine for small teams; a single file under /data, no separate DB to run.
GOGS_DB_TYPE=sqlite3
GOGS_DB_HOST=127.0.0.1:5432
GOGS_DB_NAME=gogs
GOGS_DB_USER=gogs
GOGS_DB_PASSWORD=changeme

# ── Recommended for production: Postgres ────────────────────────────────
# Deploy `database/postgres` from this catalog as its own app, then set
# these from the values you configured there (no dashboard linking on this
# tier; GOGS_DB_TYPE must change too — Gogs doesn't autodetect from the
# host):
# GOGS_DB_TYPE=postgres
# GOGS_DB_HOST=<POSTGRES_HOST>:<POSTGRES_PORT>
# GOGS_DB_NAME=<POSTGRES_DB>
# GOGS_DB_USER=<POSTGRES_USER>
# GOGS_DB_PASSWORD=<POSTGRES_PASSWORD>
