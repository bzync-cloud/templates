# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is.
#
# Gitea reads GITEA__<section>__<KEY> and writes the result to
# /data/gitea/conf/app.ini on boot (only overwriting keys you set here —
# INTERNAL_TOKEN and the OAuth2 JWT_SECRET are generated by Gitea itself on
# first boot and persisted to that same file, so they survive redeploys as
# long as the /data volume does).

# ── Required for a real deployment ─────────────────────────────────────────
# Set these once you have a domain attached in the dashboard.
GITEA__server__ROOT_URL=https://your-domain.example.com/
GITEA__server__DOMAIN=your-domain.example.com

# ── Git SSH access (optional) ───────────────────────────────────────────────
# Enable "Git SSH access" on this project's dashboard first — it shows the
# exact host/port to put here (e.g. ssh -p 20005 git@your-app.app.bzync.cloud).
# Without these, Gitea's built-in SSH daemon falls back to advertising
# "localhost" in generated clone URLs, since it has no other way to know the
# externally-reachable address. Uncomment and fill in after enabling.
# GITEA__server__SSH_DOMAIN=your-app.app.bzync.cloud
# GITEA__server__SSH_PORT=20005

# ── Security (baked into the image, listed here for visibility) ───────────
GITEA__security__INSTALL_LOCK=true
GITEA__security__SECRET_KEY=changeme

# ── Access control — production-hardened defaults ──────────────────────────
# Set both to false to open the instance up to public sign-up.
GITEA__service__DISABLE_REGISTRATION=true
GITEA__service__REQUIRE_SIGNIN_VIEW=true

# ── First admin account (auto-created on first boot) ───────────────────────
# Since registration is disabled above, bzync-entrypoint.sh creates this
# account for you once the instance is up — no docker exec required. Like
# SECRET_KEY, GITEA_ADMIN_PASSWORD=changeme is replaced with a generated
# random password at seed time; view it in the dashboard's Variables tab
# after deploy. Unset either of the first two vars to skip auto-creation
# and fall back to the manual `gitea admin user create` flow in the README.
GITEA_ADMIN_USERNAME=admin
GITEA_ADMIN_PASSWORD=changeme
GITEA_ADMIN_EMAIL=admin@your-domain.example.com

# ── Default: SQLite ──────────────────────────────────────────────────────
# Fine for small teams; a single file under /data, no separate DB to run.
GITEA__database__DB_TYPE=sqlite3

# ── Recommended for production: Postgres ────────────────────────────────
# Deploy `database/postgres` from this catalog as its own app, then set
# these from the values you configured there (no dashboard linking on this
# tier):
# GITEA__database__DB_TYPE=postgres
# GITEA__database__HOST=<POSTGRES_HOST>:<POSTGRES_PORT>
# GITEA__database__NAME=<POSTGRES_DB>
# GITEA__database__USER=<POSTGRES_USER>
# GITEA__database__PASSWD=<POSTGRES_PASSWORD>

# ── Queue backend — required if using Blue-Green or Rolling deploy strategy ─
# Gitea's default queue backend (LevelDB, under /data/gitea/queues) takes an
# exclusive process-level file lock. Blue-Green/Rolling briefly run a second
# instance against this same volume during their health-check window (that
# overlap is the whole point of both strategies) — the new instance can
# never acquire the lock and crash-loops on a fatal "unable to lock level
# db" error until the deploy times out and rolls back. Deploy
# `database/redis` from this catalog as its own app, then set these from the
# values you configured there (no dashboard linking on this tier):
# GITEA__queue__TYPE=redis
# GITEA__queue__CONN_STR=redis://:<REDIS_PASSWORD>@<REDIS_HOST>:6379/0
#
# Not needed for Standard, which always destroys the old container before
# starting the new one — only one instance ever touches the volume at a
# time there, so the default local LevelDB queue is fine as-is.

# ── Mailer (optional, needed for password resets / notifications) ─────────
# GITEA__mailer__ENABLED=true
# GITEA__mailer__SMTP_ADDR=smtp.example.com
# GITEA__mailer__SMTP_PORT=587
# GITEA__mailer__USER=
# GITEA__mailer__PASSWD=
# GITEA__mailer__FROM=gitea@your-domain.example.com
