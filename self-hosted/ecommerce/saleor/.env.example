# Passed to `docker run --env-file .env` for local dev, and also how this
# deploys on Bzync Cloud itself. The platform DOES seed these as the
# project's real env vars on first deploy (see BZYNC_CLOUD) — but any value
# literally "changeme" is replaced with a generated random secret at seed
# time, never passed through as-is.

# ── Security ────────────────────────────────────────────────────────────
# Django's secret key — used for signing, not validated for strength at
# runtime the way some other templates' secrets are, so "changeme" works
# without crashing, but treat it the same as any other secret: never
# reuse it, never leave it at the literal default in a real deployment.
SECRET_KEY=changeme

# ── First admin account ──────────────────────────────────────────────────
# bzync-entrypoint.sh runs Django's own `createsuperuser --noinput` from
# these two vars once the instance is up (native Django behavior, not a
# Saleor-specific bootstrap) — no docker exec required. Leaving
# DJANGO_SUPERUSER_PASSWORD=changeme in place gets you a working (if weak)
# password the same way other templates' secrets do; view it in the
# dashboard's Variables tab after deploy and change it from the Dashboard
# app once logged in.
DJANGO_SUPERUSER_EMAIL=admin@your-domain.example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# ── Database + broker (both required — no embedded fallback) ────────────
# Deploy `data-stores/relational/postgres` and `data-stores/cache/redis`
# (or valkey/keydb) from this catalog as their own apps, then set these
# from the values you configured there (no dashboard linking on this
# tier) — "db"/"redis" below are placeholders matching "Run locally"'s
# companion containers, not real deployed hostnames.
DATABASE_URL=postgres://app:changeme@db:5432/app
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── Recommended for a real deployment ────────────────────────────────────
# Set once you have a domain attached — Saleor uses it for CSRF/host
# validation and links in outgoing emails.
ALLOWED_HOSTS=*
DEFAULT_FROM_EMAIL=noreply@your-domain.example.com
