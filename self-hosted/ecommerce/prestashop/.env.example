# Passed to `docker run --env-file .env` for local dev, and also how this
# deploys on Bzync Cloud itself. The platform DOES seed these as the
# project's real env vars on first deploy (see BZYNC_CLOUD) — but any value
# literally "changeme" is replaced with a generated random secret at seed
# time, never passed through as-is.

# ── Database (required — no SQLite fallback) ────────────────────────────
# Deploy `data-stores/relational/mysql` (or `mariadb`) from this catalog
# as its own app, then set these from the values you configured there (no
# dashboard linking on this tier) — "db" below is a placeholder matching
# "Run locally"'s companion MySQL container, not a real deployed hostname.
DB_SERVER=db
DB_NAME=app
DB_USER=app
DB_PASSWD=changeme

# ── First admin account ──────────────────────────────────────────────────
# PS_INSTALL_AUTO runs PrestaShop's full installer non-interactively on
# first boot and creates this account as part of it (native image
# behavior, no wrapper script needed here). Leaving ADMIN_PASSWD=changeme
# in place gets you a working (if weak) password the same way other
# templates' secrets do; view it in the dashboard's Variables tab after
# deploy and change it from the back office once logged in.
ADMIN_MAIL=admin@your-domain.example.com
ADMIN_PASSWD=changeme

# ── Required for a real deployment ─────────────────────────────────────────
# Set once you have a domain attached — PrestaShop bakes this into every
# link and asset URL it generates during install. Changing it after
# install requires re-running the installer against a fresh /var/www/html
# volume, not just updating this var.
PS_DOMAIN=your-domain.example.com

# ── Recommended ────────────────────────────────────────────────────────
PS_LANGUAGE=en
PS_COUNTRY=us
