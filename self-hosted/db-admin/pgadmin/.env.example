# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is.

# ── Required — the container refuses to start without both ─────────────────
# This is pgAdmin's own login, unrelated to any Postgres server's
# credentials — you add those separately from inside the UI after logging
# in. Leave the password as "changeme"; see the note above.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# ── Optional ─────────────────────────────────────────────────────────────
# PGADMIN_CONFIG_SERVER_MODE=True          # multi-user mode (default)
# PGADMIN_LISTEN_PORT=80                   # must match Dockerfile's EXPOSE
# PGADMIN_CONFIG_ENHANCED_COOKIE_PROTECTION=True
