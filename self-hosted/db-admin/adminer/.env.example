# Local dev container (docker run/compose). For a Bzync Cloud deploy, the
# platform DOES seed these as the project's real env vars on first deploy
# (see BZYNC_CLOUD).
#
# Adminer holds no credentials of its own — there's nothing here to
# configure connections. Everything below only changes the UI.

# ── Appearance ──────────────────────────────────────────────────────────────
# One of the theme names under /var/www/html/designs in the image (brade,
# ce, dracula, flat, galkaev, hydra, jukin, konya, lucas-sandery, matis,
# mancave, nette, nicu, pappu687, pepa-linha, pepa-linha-dark, price,
# rmmartins, ruby, umbra, worn-cd). Applied once on first boot only — later
# changes here don't retroactively override a persisted adminer.css symlink.
ADMINER_DESIGN=pepa-linha

# ── Plugins (advanced, optional) ───────────────────────────────────────────
# Space-separated plugin names from /var/www/html/plugins to auto-enable —
# only for plugins with a no-argument constructor (e.g. tinymce,
# edit-textarea). Plugins that take constructor arguments (login-servers,
# login-ip, ...) need a hand-written file under plugins-enabled/ instead;
# see https://www.adminer.org/plugins/#use.
# ADMINER_PLUGINS=tinymce edit-textarea
