HOST=0.0.0.0
PORT=1337
APP_KEYS=change-me-1,change-me-2
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me

# Database — link a Postgres database in the Bzync Cloud dashboard.
# The platform injects DB_HOST, DB_PORT, DB_NAME, DB_USER, and DB_PASSWORD
# automatically; config/database.js reads these directly. Without a linked
# database these fall back to a local Postgres at 127.0.0.1 for `strapi
# develop` against a database you run yourself.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=strapi
DB_USER=strapi
DB_PASSWORD=strapi
