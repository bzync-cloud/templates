---
const apiUrl = import.meta.env.API_URL || "http://backend:1337";
let status = "unknown";
try {
  const res = await fetch(`${apiUrl}/_health`);
  status = (await res.json()).status;
} catch {
  status = "unavailable";
}
---
<html lang="en">
  <body>
    <h1>Astro + Strapi</h1>
    <p>API status: {status}</p>
  </body>
</html>
