# Environment variables for this project.
# Set these in the Bzync Cloud dashboard under each environment.
#
# The default uses SQLite so a new starter deploys without a separate database.
# Switch to PostgreSQL or MySQL below when you attach a managed database.

PORT=8055
PUBLIC_URL=https://your-domain.com

# Directus security — replace with random values
KEY=replace-with-a-random-uuid
SECRET=replace-with-a-random-secret

# Admin credentials (used only on first bootstrap)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# ── Default: SQLite ───────────────────────────────────────────────
DB_CLIENT=sqlite3
DB_FILENAME=/directus/database/data.db

# ── PostgreSQL ────────────────────────────────────────────────────
# DB_CLIENT=pg
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=directus
# DB_USER=directus
# DB_PASSWORD=your-db-password
# POSTGRES_USER=directus
# POSTGRES_PASSWORD=your-db-password
# POSTGRES_DB=directus

# ── Option 2: MySQL ───────────────────────────────────────────────
# DB_CLIENT=mysql2
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=directus
# DB_USER=directus
# DB_PASSWORD=your-db-password
# MYSQL_ROOT_PASSWORD=your-root-password
# MYSQL_DATABASE=directus
# MYSQL_USER=directus
# MYSQL_PASSWORD=your-db-password
