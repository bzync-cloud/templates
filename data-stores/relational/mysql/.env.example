# Local dev container (docker-compose.yml), and also how this database
# deploys on Bzync Cloud itself — this tier has no managed/linked database
# service (mdb was removed; see the workspace root README.md), so this
# template deployed as its own app *is* the database. The platform DOES
# seed these as the project's real env vars on first deploy (see
# BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is. See
# README.md for the values to copy into any other app that needs to
# connect (no automatic injection between apps here).

MYSQL_VERSION=8.0
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=changeme
MYSQL_PORT=3306
