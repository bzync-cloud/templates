# Passed to `docker run --env-file .env` for local dev, and also how this
# database deploys on Bzync Cloud itself — this tier has no managed/linked
# database service (mdb was removed; see the workspace root `README.md`), so
# this template deployed as its own app *is* the database. The platform
# DOES seed these as the project's real env vars on first deploy (see
# BZYNC_CLOUD) — but any value literally "changeme" is replaced with a
# generated random secret at seed time, never passed through as-is. See
# README.md for the values to copy into any other app that needs to
# connect (no automatic injection between apps here).

GARAGE_VERSION=

# Admin/metrics API auth — Garage reads these directly, they're not baked
# into garage.toml. (Cluster RPC auth isn't here: Garage requires it be a
# 32-byte hex string, which conflicts with this platform's random-secret
# generator, so bzync-entrypoint.sh generates it fresh on every container
# start instead — see that file.)
GARAGE_ADMIN_TOKEN=changeme
GARAGE_METRICS_TOKEN=changeme

# Auto-created on first start via `--default-bucket` (Garage v2.3.0+) —
# this is the S3 access/secret key pair and the bucket it's scoped to.
# Both are "changeme" (unlike minio's separate static MINIO_ROOT_USER):
# Garage's access key has its own minimum length (8 chars) that the
# literal string "changeme" itself already satisfies. The secret key's
# separate minimum is 16 chars, which "changeme" does not satisfy on its
# own — bzync-entrypoint.sh deterministically pads the literal placeholder
# before Garage starts (see that file); once the platform's seed-time
# generator replaces "changeme" with a real value in production, that
# padding is a no-op.
GARAGE_DEFAULT_ACCESS_KEY=changeme
GARAGE_DEFAULT_SECRET_KEY=changeme
GARAGE_DEFAULT_BUCKET=default
