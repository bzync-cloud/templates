{
  "name": "bzync/laravel-starter",
  "type": "project",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^11.0",
    "laravel/tinker": "^2.9",
    "laravel/sanctum": "^4.0"
  },
  "require-dev": {
    "laravel/sail": "^1.26",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
